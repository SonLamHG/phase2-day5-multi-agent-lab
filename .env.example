# Required if using a real LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=2

# Optional tracing providers
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGSMITH_TRACING=true

# Optional search provider
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
